{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "sourceMap": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node","aws-lambda"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "index.ts",
        "./helloHandler.ts"
    ]
}
